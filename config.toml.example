# =============================================================================
# MeshCore Packet Capture - Configuration Reference
# =============================================================================
# Load order (default):
#   1. /etc/meshcore-packet-capture/config.toml
#   2. /etc/meshcore-packet-capture/config.d/*.toml (sorted)
#
# Put local overrides in config.d/99-user.toml. Presets install as 10-*.toml.
# Use --config PATH (repeatable) to load only those files, in order.
# =============================================================================

[general]
iata = "LOC"
log_level = "INFO"

[topics]
status = "meshcore/{IATA}/{PUBLIC_KEY}/status"
packets = "meshcore/{IATA}/{PUBLIC_KEY}/packets"
# raw = "meshcore/{IATA}/{PUBLIC_KEY}/raw"

[serial]
ports = ["/dev/ttyUSB0"]
baud_rate = 115200
timeout = 2

[update]
repo = "agessaman/meshcore-packet-capture"
branch = "main"

# Connection and runtime options (packet capture specific)
[capture]
connection_type = "ble"
timeout = 30
tcp_host = "localhost"
tcp_port = 5000
# ble_address = "XX:XX:XX:XX:XX:XX"
# ble_device_name = "MeshCore Device"
# ble_pin = "123456"  # Optional six-digit PIN passed to the BLE connection
#                     # Linux may still require BlueZ pairing during first-time setup
advert_interval_hours = 47
# State directory for advert_state.json (installer creates and chowns this path)
data_dir = "/var/lib/meshcore-packet-capture/data"
max_connection_retries = 5
connection_retry_delay = 5
health_check_interval = 30
max_mqtt_retries = 5
mqtt_retry_delay = 5
jwt_renewal_interval = 3600
jwt_renewal_threshold = 300
rf_data_timeout = 15.0
# Additional runtime controls (optional)
# connection_retry_delay_max = 300
# connection_retry_backoff_multiplier = 2.0
# connection_retry_jitter = true
# drain_messages = true
# tcp_keepalive_enabled = true
# tcp_keepalive_idle = 10
# tcp_keepalive_interval = 5
# tcp_keepalive_count = 3
# binary_interface_enabled = false
# binary_interface_host = "0.0.0.0"
# binary_interface_port = 5001
# owner_public_key = ""
# owner_email = ""

# --- Payload decoding (adds a nested "decoded" object with plain text / structured fields) ---
# When enabled, GRP_TXT channel messages are decrypted (sender, text), ADVERTs are parsed
# (name, role, lat/lon), and human-readable type/route labels + path are included. Raw fields
# are unchanged. Direct messages (TXT_MSG) cannot be decrypted by a passive observer.
# decode_payloads = false
# include_decoded = false           # Global default (off); opt in per broker with include_decoded below
# decode_hashtag_channels = ["bot", "weather"]   # Public/hashtag channels; keys derived from name
# decode_channel_keys = "name=hexOrBase64,other=..."  # Custom channel keys (16-byte hex or base64)
# decode_include_public = true      # Include the well-known default "Public" channel key

# --- Packet log rotation (only applies when an output file is given with --output) ---
# log_rotation = "off"              # off | size | time
# log_max_bytes = "50MB"            # size mode threshold (accepts 50MB, 10M, ...)
# log_rotation_when = "midnight"    # time mode interval (midnight, H, D, W0-W6)
# log_backup_count = 5              # rolled files to keep

# [[broker]] blocks merge by name across files. See presets/letsmesh.toml.

# [[broker]]
# name = "example"
# enabled = false
# server = "mqtt.example.com"
# port = 1883
# transport = "tcp"
# keepalive = 60
# qos = 0
# retain = true
# include_decoded = true   # Publish the "decoded" object to this broker (default: capture.include_decoded, off)
#
# [broker.tls]
# enabled = false
# verify = true
#
# [broker.auth]
# method = "password"
# username = ""
# password = ""
# topic_token = "" # Optional: used for {TOKEN} placeholder in broker.topics templates
#
# For method = "token" brokers:
# audience = "mqtt.example.com"
# token_ttl = 3600  # Optional: JWT lifetime in seconds (default 86400 = 24h)
# owner = "64_hex_char_public_key"   # Optional; overrides capture.owner_public_key for this broker
# email = "you@example.com"          # Optional; overrides capture.owner_email for this broker
#
# Optional per-broker topic overrides (take precedence over the global [topics];
# unset keys fall back to [topics]) for status/packets/decoded/debug/raw.
# COMMAND is intentionally per-broker only (no global fallback) to prevent
# accidental enablement on community brokers.
# Keys for general topics: status, packets, decoded, debug, raw.
# [broker.topics]
# packets = "custom/{IATA}/{PUBLIC_KEY}/packets"

# --- MQTT Command Ingress (per-broker only, explicit opt-in) ---
# Allows MQTT to trigger radio TX (send_msg, send_chan_msg). Secure with broker ACLs.
#
# REQUIRED (both on same broker) - either disabled or fully set:
#   [broker.command]
#   commands_enabled = true                              # explicit gate, topic alone does NOT enable
#   topic_command = "meshcore/{IATA}/{PUBLIC_KEY}/command/+"  # MQTT wildcard: matches send_msg and send_chan_msg
#   # Examples you would publish to:
#   #   meshcore/{IATA}/{PUBLIC_KEY}/command/send_msg       -> direct message
#   #   meshcore/{IATA}/{PUBLIC_KEY}/command/send_chan_msg  -> channel message
#
# OPTIONAL hardening (recommended):
#   command_hmac_key = "your-shared-secret-min-32-chars" # if set, payload MUST include valid hmac
#   command_max_rate = 10                                # max cmds per window (default 10)
#   command_rate_window = 60                             # rate-limit window seconds (default 60)
#   command_max_age = 300                                # reject if timestamp older than N sec (default 300)
#   command_future_skew = 60                             # allow N sec future skew (default 60)
#
# Payload (JSON): timestamp required (epoch/ISO8601), nonce recommended, hmac required if key set.
#   send_msg: {"destination":"<hex pubkey>","message":"hi","timestamp":1710000000,"nonce":"uuid"}
#   send_chan_msg: {"channel":0,"message":"hi","timestamp":1710000000,"nonce":"uuid"}
#   With HMAC: add "hmac":"hex-hmac-sha256(command_type.timestamp.nonce.canonical_json_core)"
# Command type comes from last topic segment (.../command/send_msg), not payload field.
# Retained messages are always dropped. See README for full details and examples.

